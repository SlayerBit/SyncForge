# -----------------------------------------------------------------------------
# SyncForge Environment Variables Template (.env.example)
# Copy this file to '.env' and populate with production values before deploying.
# -----------------------------------------------------------------------------

# Active Spring Profile (e.g., dev, prod)
SPRING_PROFILES_ACTIVE=prod

# PostgreSQL Configuration
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/syncforge
SPRING_DATASOURCE_USERNAME=syncforge
SPRING_DATASOURCE_PASSWORD=your_secure_postgres_password_here

# Redis Configuration
SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379

# SMTP Configuration for Email Verification
SYNCFORGE_MAIL_HOST=smtp.mailtrap.io
SYNCFORGE_MAIL_PORT=2525
SYNCFORGE_MAIL_USERNAME=your_smtp_username
SYNCFORGE_MAIL_PASSWORD=your_smtp_password

# Authentication / Security Configuration
# JWT secret must be a cryptographically strong string, at least 32 characters long.
SYNCFORGE_JWT_SECRET=your_super_secret_signing_key_at_least_32_characters_long
SYNCFORGE_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
SYNCFORGE_BASE_URL=http://localhost:8080
